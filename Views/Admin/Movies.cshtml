@model List<webkino.ViewModels.MovieViewModel>

@{
    ViewData["Title"] = "Керування фільмами";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h1>Керування фільмами</h1>
        <p class="text-muted mb-0">Список усіх фільмів у системі</p>
    </div>
    <a asp-controller="Admin" asp-action="CreateMovie" class="btn btn-success">
        Додати фільм
    </a>
</div>

@if (TempData["AdminSuccess"] != null)
{
    <div class="alert alert-success">@TempData["AdminSuccess"]</div>
}

@if (TempData["AdminError"] != null)
{
    <div class="alert alert-danger">@TempData["AdminError"]</div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">У базі даних поки немає фільмів.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle custom-table">
            <thead>
                <tr>
                    <th>Назва</th>
                    <th>Рік</th>
                    <th>Рейтинг</th>
                    <th>Студія</th>
                    <th>Відео</th>
                    <th>Дії</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var movie in Model)
                {
                    <tr>
                        <td>@movie.Title</td>
                        <td>@movie.ReleaseYear</td>
                        <td>@movie.Rating</td>
                        <td>@movie.StudioName</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(movie.VideoUrl))
                            {
                                <a href="@movie.VideoUrl" target="_blank" class="btn btn-sm btn-outline-primary">Відкрити</a>
                            }
                            else
                            {
                                <span class="text-muted">Немає</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-2 flex-wrap">
                                <a asp-controller="Admin"
                                   asp-action="EditMovie"
                                   asp-route-id="@movie.Id"
                                   class="btn btn-sm btn-warning">
                                    Редагувати
                                </a>

                                <form asp-controller="Admin"
                                      asp-action="DeleteMovie"
                                      asp-route-id="@movie.Id"
                                      method="post"
                                      onsubmit="return confirm('Видалити цей фільм?');">
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        Видалити
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}