@model webkino.ViewModels.UserProfileViewModel

@{
    ViewData["Title"] = "Профіль";
}

<h1 class="mb-4">Профіль користувача</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <p><strong>Ім'я користувача:</strong> @Model.Username</p>
        <p><strong>Email:</strong> @Model.Email</p>
        <p><strong>Роль:</strong> @Model.Role</p>
    </div>
</div>